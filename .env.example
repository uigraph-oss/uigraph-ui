NEXT_PUBLIC_API_URL=https://api.dev.uigraph.app
# Public base URL for stored assets. The browser reads every blob (frame
# screenshots, diagram thumbnails, diagram images) directly from object storage
# at ${NEXT_PUBLIC_ASSETS_URL}/<assetId> — the app is never in the read path.
# Local Docker (MinIO bucket "uigraph", public "assets/" prefix):
NEXT_PUBLIC_ASSETS_URL=http://localhost:9000/uigraph/assets
# Production: front MinIO with your reverse proxy/CDN, e.g.
#   NEXT_PUBLIC_ASSETS_URL=https://assets.your-domain.com
NEXT_PUBLIC_DEPLOY_ENV=development

NEXT_PUBLIC_WS_URL=wss://ws.dev.uigraph.app/project-manager
NEXT_PUBLIC_AI_WS_URL=wss://ws.dev.uigraph.app/intelligence
