# UIGraph UI (Vite). Only VITE_-prefixed vars are exposed to the browser bundle
# via import.meta.env. Copy to .env and adjust as needed.

# local | development | production. Controls env-specific UI behavior.
VITE_DEPLOY_ENV=local

# Public origin of this UI, used to build absolute links. Falls back to
# VITE_CLIENT_URL, then https://uigraph.app.
VITE_APP_URL=http://localhost:3000

# Object storage origin for serving assets (frame images, docs).
VITE_ASSETS_URL=http://localhost:9000/uigraph/assets

# GraphQL endpoint. Leave unset to use the "/graphql" dev proxy (see
# vite.config.mjs server.proxy -> VITE_GRAPHQL_TARGET, default :8090).
# VITE_GRAPHQL_ENDPOINT=/graphql

# Skip the email-domain allow-list check on sign-in (dev convenience).
VITE_BYPASS_DOMAIN_CHECK=true

# Feature flags.
VITE_FEATURE_SSO_ENABLED=false
VITE_FEATURE_ENABLE_DEMO_TEST_CASES=false

# Figma import OAuth. NOTE: anything VITE_-prefixed is inlined into the public
# client bundle, so VITE_FIGMA_CLIENT_SECRET is exposed to the browser. Leave
# blank to disable Figma import, or move the token exchange to the backend.
VITE_FIGMA_CLIENT_ID=
VITE_FIGMA_CLIENT_SECRET=
VITE_FIGMA_REDIRECT_URI=

# ── Dev-server only (Node, not bundled) ──────────────────────────────────────
# Reverse-proxy targets used by vite.config.mjs during `npm run dev`.
# VITE_API_TARGET=http://127.0.0.1:8080
# VITE_GRAPHQL_TARGET=http://127.0.0.1:8090
