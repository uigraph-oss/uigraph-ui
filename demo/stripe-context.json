{
  "name": "Stripe payment flow context",
  "description": "Context for the Stripe payment intent lifecycle: client-side payment, 3D Secure authentication, webhook handling, and edge cases.",
  "nodes": {
    "A": {
      "name": "User clicks Pay",
      "type": "shape",
      "shape": "rounded-rect",
      "data": {
        "Component": { "type": "Text Input", "value": "CheckoutButton" },
        "Framework": {
          "type": "Dropdown",
          "value": "React",
          "options": ["React", "Vue", "Svelte", "Angular"]
        }
      },
      "style": {
        "fill": "#635bff",
        "stroke": "#4b45c6",
        "strokeWidth": 2,
        "borderRadius": 4
      }
    },
    "B": {
      "name": "Create Payment Intent request to backend",
      "data": {
        "Endpoint": {
          "type": "Text Input",
          "value": "POST /api/payments/create-intent"
        },
        "Auth": {
          "type": "Dropdown",
          "value": "Bearer token",
          "options": ["Bearer token", "Session cookie", "API key"]
        },
        "Idempotency": { "type": "Boolean Toggle", "value": true }
      }
    },
    "C": {
      "name": "Backend calls Stripe API: Create PaymentIntent",
      "type": "cloud",
      "cloud": "AWS",
      "service": "AWS Lambda",
      "data": {
        "Stripe API version": { "type": "Text Input", "value": "2024-12-18" },
        "Currency": {
          "type": "Dropdown",
          "value": "usd",
          "options": ["usd", "eur", "gbp", "jpy"]
        },
        "Capture method": {
          "type": "Dropdown",
          "value": "automatic",
          "options": ["automatic", "manual"]
        },
        "Idempotency key": { "type": "Boolean Toggle", "value": true },
        "Metadata": {
          "type": "Key-Value List",
          "value": [{ "key": "order_id", "value": "ord_xxx" }]
        }
      },
      "style": {
        "fill": "#f97316",
        "stroke": "#ea580c",
        "strokeWidth": 2,
        "borderRadius": 4
      }
    },
    "D": {
      "name": "Stripe returns client_secret",
      "data": {
        "Response fields": {
          "type": "Tag Input",
          "value": ["id", "client_secret", "status", "amount"]
        },
        "Status": { "type": "Text Input", "value": "requires_payment_method" }
      },
      "style": {
        "fill": "#635bff",
        "stroke": "#4b45c6",
        "strokeWidth": 2,
        "borderRadius": 4
      }
    },
    "E": {
      "name": "Backend sends client_secret to client",
      "data": {
        "Response format": {
          "type": "Dropdown",
          "value": "JSON",
          "options": ["JSON", "GraphQL"]
        },
        "Fields exposed": {
          "type": "Tag Input",
          "value": ["clientSecret", "paymentIntentId", "amount"]
        },
        "Notes": {
          "type": "Text Editor",
          "value": "Never expose the full PaymentIntent object. Only return client_secret and minimal metadata."
        }
      }
    },
    "F": {
      "name": "Client confirms payment using Stripe.js / SDK",
      "data": {
        "SDK": {
          "type": "Dropdown",
          "value": "Stripe.js v3",
          "options": [
            "Stripe.js v3",
            "React Stripe.js",
            "iOS SDK",
            "Android SDK"
          ]
        },
        "Method": {
          "type": "Text Input",
          "value": "stripe.confirmCardPayment(clientSecret)"
        },
        "Payment Element": { "type": "Boolean Toggle", "value": true },
        "Notes": {
          "type": "Rich Text Editor",
          "value": "Uses the **Payment Element** for unified payment method collection.\n\nSupports:\n- Credit/debit cards\n- Apple Pay / Google Pay\n- Bank redirects (iDEAL, SEPA)\n- Buy now, pay later"
        }
      },
      "style": {
        "fill": "#635bff",
        "stroke": "#4b45c6",
        "strokeWidth": 2,
        "borderRadius": 4,
        "borderAnimationEnabled": true
      }
    },
    "G": {
      "name": "Payment requires action?",
      "type": "shape",
      "shape": "diamond",
      "data": {
        "SCA regions": { "type": "Tag Input", "value": ["EU", "UK", "India"] },
        "Notes": {
          "type": "Text Editor",
          "value": "Stripe automatically determines if 3DS/SCA is needed based on card issuer, region, and risk assessment."
        }
      },
      "style": {
        "fill": "#fbbf24",
        "stroke": "#d97706",
        "strokeWidth": 2,
        "borderRadius": 2
      }
    },
    "H": {
      "name": "Trigger 3D Secure / Authentication",
      "data": {
        "Protocol": {
          "type": "Dropdown",
          "value": "3DS2",
          "options": ["3DS1", "3DS2"]
        },
        "Timeout (sec)": { "type": "Number Input", "value": 300 },
        "Liability shift": { "type": "Boolean Toggle", "value": true },
        "Notes": {
          "type": "Text Editor",
          "value": "Stripe.js handles the 3DS modal/redirect automatically. No additional frontend code needed if using Payment Element."
        }
      },
      "style": {
        "fill": "#fb923c",
        "stroke": "#ea580c",
        "strokeWidth": 2,
        "borderRadius": 4,
        "strokeStyle": "dashed"
      }
    },
    "I": {
      "name": "Authentication success?",
      "type": "shape",
      "shape": "diamond",
      "data": {
        "Failure reasons": {
          "type": "Tag Input",
          "value": ["user_cancelled", "auth_failed", "timeout", "not_supported"]
        }
      },
      "style": {
        "fill": "#fbbf24",
        "stroke": "#d97706",
        "strokeWidth": 2,
        "borderRadius": 2
      }
    },
    "J": {
      "name": "Payment Failed",
      "data": {
        "Error code": {
          "type": "Text Input",
          "value": "authentication_required"
        },
        "Decline code": { "type": "Text Input", "value": "" },
        "Notes": {
          "type": "Text Editor",
          "value": "Log failure reason for analytics. Present user-friendly error message, not raw Stripe error."
        }
      },
      "style": {
        "fill": "#ef4444",
        "stroke": "#dc2626",
        "strokeWidth": 2,
        "borderRadius": 4
      }
    },
    "K": {
      "name": "Continue payment confirmation",
      "data": {
        "Status": {
          "type": "Text Input",
          "value": "requires_confirmation → processing"
        }
      }
    },
    "L": {
      "name": "Payment outcome",
      "type": "shape",
      "shape": "diamond",
      "data": {
        "Possible statuses": {
          "type": "Tag Input",
          "value": ["succeeded", "processing", "requires_payment_method"]
        }
      },
      "style": {
        "fill": "#fbbf24",
        "stroke": "#d97706",
        "strokeWidth": 2,
        "borderRadius": 2
      }
    },
    "M": {
      "name": "PaymentIntent status = succeeded",
      "data": {
        "Charge created": { "type": "Boolean Toggle", "value": true },
        "Balance transaction": { "type": "Boolean Toggle", "value": true },
        "Notes": {
          "type": "Text Editor",
          "value": "Funds are captured. Safe to fulfill the order. Always verify via webhook before shipping."
        }
      },
      "style": {
        "fill": "#22c55e",
        "stroke": "#15803d",
        "strokeWidth": 2,
        "borderRadius": 4
      }
    },
    "N": {
      "name": "PaymentIntent status = processing",
      "data": {
        "Payment methods": {
          "type": "Tag Input",
          "value": ["ACH", "SEPA", "iDEAL", "Sofort", "BACS"]
        },
        "Expected resolution": {
          "type": "Text Input",
          "value": "1-5 business days"
        },
        "Notes": {
          "type": "Text Editor",
          "value": "Common for bank-based payment methods. Do NOT fulfill until webhook confirms success."
        }
      },
      "style": {
        "fill": "#3b82f6",
        "stroke": "#2563eb",
        "strokeWidth": 2,
        "borderRadius": 4,
        "strokeStyle": "dashed"
      }
    },
    "O": {
      "name": "PaymentIntent status = requires_payment_method",
      "data": {
        "Reason": {
          "type": "Text Input",
          "value": "Card declined or insufficient funds"
        },
        "Decline codes": {
          "type": "Tag Input",
          "value": [
            "insufficient_funds",
            "lost_card",
            "stolen_card",
            "generic_decline"
          ]
        }
      },
      "style": {
        "fill": "#ef4444",
        "stroke": "#dc2626",
        "strokeWidth": 2,
        "borderRadius": 4
      }
    },
    "P": {
      "name": "Client receives success response",
      "data": {
        "Response": {
          "type": "Code Editor",
          "value": "// Stripe.js response\n{\n  paymentIntent: {\n    id: 'pi_xxx',\n    status: 'succeeded'\n  }\n}"
        }
      }
    },
    "Q": {
      "name": "Show success UI",
      "data": {
        "Component": { "type": "Text Input", "value": "OrderConfirmation" },
        "Redirect to": { "type": "URL Input", "value": "/order/confirmation" },
        "Show receipt": { "type": "Boolean Toggle", "value": true }
      },
      "style": {
        "fill": "#22c55e",
        "stroke": "#15803d",
        "strokeWidth": 2,
        "borderRadius": 4
      }
    },
    "R": {
      "name": "Wait for webhook confirmation",
      "data": {
        "Polling interval (sec)": { "type": "Number Input", "value": 5 },
        "Max wait (sec)": { "type": "Number Input", "value": 600 },
        "Notes": {
          "type": "Text Editor",
          "value": "Show a pending state to the user. Poll order status or use WebSocket for real-time updates."
        }
      },
      "style": {
        "fill": "#3b82f6",
        "stroke": "#2563eb",
        "strokeWidth": 2,
        "borderRadius": 4,
        "strokeStyle": "dotted",
        "borderAnimationEnabled": true
      }
    },
    "S": {
      "name": "Client shows error",
      "data": {
        "Error display": {
          "type": "Dropdown",
          "value": "Inline banner",
          "options": ["Inline banner", "Toast", "Modal"]
        },
        "User-facing message": {
          "type": "Text Input",
          "value": "Your payment was declined. Please try a different payment method."
        }
      },
      "style": {
        "fill": "#ef4444",
        "stroke": "#dc2626",
        "strokeWidth": 2,
        "borderRadius": 4
      }
    },
    "T": {
      "name": "User retries payment",
      "data": {
        "Max retries": { "type": "Number Input", "value": 3 },
        "Reset form": { "type": "Boolean Toggle", "value": false }
      }
    },
    "W1": {
      "name": "Stripe sends webhook event",
      "data": {
        "Webhook URL": {
          "type": "URL Input",
          "value": "https://api.example.com/webhooks/stripe"
        },
        "Signing secret": { "type": "Text Input", "value": "whsec_xxx" },
        "Tolerance (sec)": { "type": "Number Input", "value": 300 },
        "Notes": {
          "type": "Rich Text Editor",
          "value": "**Always verify** the webhook signature using `stripe.webhooks.constructEvent()`.\n\nStripe retries failed webhooks for up to **3 days** with exponential backoff."
        }
      },
      "style": {
        "fill": "#635bff",
        "stroke": "#4b45c6",
        "strokeWidth": 2,
        "borderRadius": 4,
        "borderAnimationEnabled": true
      }
    },
    "W2": {
      "name": "Event type",
      "type": "shape",
      "shape": "diamond",
      "data": {
        "Events to handle": {
          "type": "Tag Input",
          "value": [
            "payment_intent.succeeded",
            "payment_intent.processing",
            "payment_intent.payment_failed",
            "charge.refunded",
            "charge.dispute.created"
          ]
        }
      },
      "style": {
        "fill": "#fbbf24",
        "stroke": "#d97706",
        "strokeWidth": 2,
        "borderRadius": 2
      }
    },
    "W3": {
      "name": "Mark order as paid",
      "type": "data-source",
      "dbConfig": {
        "service": "UIGraph Adapter",
        "database": "ecommerce",
        "tableName": "orders"
      },
      "data": {
        "Status": { "type": "Text Input", "value": "paid" },
        "Trigger fulfillment": { "type": "Boolean Toggle", "value": true },
        "Send receipt email": { "type": "Boolean Toggle", "value": true }
      },
      "style": {
        "fill": "#22c55e",
        "stroke": "#15803d",
        "strokeWidth": 2,
        "borderRadius": 4
      }
    },
    "W4": {
      "name": "Mark order as pending",
      "type": "data-source",
      "dbConfig": {
        "service": "UIGraph Adapter",
        "database": "ecommerce",
        "tableName": "orders"
      },
      "data": {
        "Status": { "type": "Text Input", "value": "pending" },
        "Notify user": { "type": "Boolean Toggle", "value": true }
      },
      "style": {
        "fill": "#3b82f6",
        "stroke": "#2563eb",
        "strokeWidth": 2,
        "borderRadius": 4
      }
    },
    "W5": {
      "name": "Mark order as failed",
      "type": "data-source",
      "dbConfig": {
        "service": "UIGraph Adapter",
        "database": "ecommerce",
        "tableName": "orders"
      },
      "data": {
        "Status": { "type": "Text Input", "value": "failed" },
        "Send failure email": { "type": "Boolean Toggle", "value": true },
        "Auto-cancel after (hours)": { "type": "Number Input", "value": 24 }
      },
      "style": {
        "fill": "#ef4444",
        "stroke": "#dc2626",
        "strokeWidth": 2,
        "borderRadius": 4
      }
    },
    "W6": {
      "name": "Handle refund",
      "data": {
        "Refund types": { "type": "Tag Input", "value": ["full", "partial"] },
        "Update inventory": { "type": "Boolean Toggle", "value": true },
        "Notes": {
          "type": "Text Editor",
          "value": "Refund amount is in the charge.refunded event. Update order status and notify customer."
        }
      },
      "style": {
        "fill": "#a855f7",
        "stroke": "#7c3aed",
        "strokeWidth": 2,
        "borderRadius": 4
      }
    },
    "W7": {
      "name": "Handle dispute",
      "data": {
        "Response deadline (days)": { "type": "Number Input", "value": 7 },
        "Evidence required": {
          "type": "Tag Input",
          "value": ["receipt", "shipping_proof", "customer_communication"]
        },
        "Notes": {
          "type": "Rich Text Editor",
          "value": "**Critical:** Disputes must be responded to within the deadline or the funds are automatically returned.\n\nCollect evidence:\n- Delivery confirmation\n- Customer correspondence\n- Product description\n- Refund policy"
        }
      },
      "style": {
        "fill": "#f43f5e",
        "stroke": "#e11d48",
        "strokeWidth": 2,
        "borderRadius": 4,
        "strokeStyle": "dashed"
      }
    },
    "E1": {
      "name": "Network failure before confirmation",
      "data": {
        "Retry strategy": {
          "type": "Dropdown",
          "value": "Exponential backoff",
          "options": ["Exponential backoff", "Fixed interval", "No retry"]
        },
        "Max retries": { "type": "Number Input", "value": 3 },
        "Notes": {
          "type": "Text Editor",
          "value": "Use PaymentIntent ID to retrieve status on reconnection. Never create a new PaymentIntent — reuse the existing one."
        }
      },
      "style": {
        "fill": "#fbbf24",
        "stroke": "#d97706",
        "strokeWidth": 2,
        "borderRadius": 4,
        "strokeStyle": "dotted"
      }
    },
    "E2": {
      "name": "Duplicate submission",
      "data": {
        "Prevention": {
          "type": "Tag Input",
          "value": ["disable_button", "idempotency_key", "debounce"]
        },
        "Notes": {
          "type": "Text Editor",
          "value": "Frontend: disable submit button immediately. Backend: use Stripe idempotency keys to prevent duplicate charges."
        }
      },
      "style": {
        "fill": "#fbbf24",
        "stroke": "#d97706",
        "strokeWidth": 2,
        "borderRadius": 4,
        "strokeStyle": "dotted"
      }
    },
    "E3": {
      "name": "User closes browser",
      "data": {
        "Recovery": {
          "type": "Text Input",
          "value": "Webhook still fires — order is updated server-side"
        },
        "Notes": {
          "type": "Text Editor",
          "value": "Payment may still succeed even if the user closes the browser. Webhook is the source of truth."
        }
      },
      "style": {
        "fill": "#fbbf24",
        "stroke": "#d97706",
        "strokeWidth": 2,
        "borderRadius": 4,
        "strokeStyle": "dotted"
      }
    },
    "E4": {
      "name": "Webhook delay",
      "data": {
        "Typical delay (sec)": { "type": "Number Input", "value": 5 },
        "Max delay (hours)": { "type": "Number Input", "value": 72 },
        "Notes": {
          "type": "Text Editor",
          "value": "Webhooks are usually near-instant but can be delayed. Implement polling as a fallback for time-sensitive flows."
        }
      },
      "style": {
        "fill": "#fbbf24",
        "stroke": "#d97706",
        "strokeWidth": 2,
        "borderRadius": 4,
        "strokeStyle": "dotted"
      }
    },
    "E5": {
      "name": "Idempotency key prevents duplicates",
      "data": {
        "Key format": {
          "type": "Text Input",
          "value": "order_{orderId}_payment_{attempt}"
        },
        "TTL (hours)": { "type": "Number Input", "value": 24 },
        "Notes": {
          "type": "Text Editor",
          "value": "Stripe caches idempotent responses for 24 hours. Use a deterministic key derived from your order ID."
        }
      },
      "style": {
        "fill": "#22c55e",
        "stroke": "#15803d",
        "strokeWidth": 2,
        "borderRadius": 4,
        "strokeStyle": "dashed"
      }
    },
    "Z": {
      "name": "End",
      "type": "shape",
      "shape": "terminator"
    }
